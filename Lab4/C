/*
 * Medidor de temperatura con LM35, displays 7 segmentos, LEDs y alarma sonora
 * PIC16F887, XC8, oscilador interno 8 MHz
 * 
 * Rango de alarma: 15°C a 25°C (fuera de ese rango suena el buzzer)
 * Rango de LEDs: frío (<15°C) azules, normal (15-25°C) blancos, caliente (>25°C) rojos
 */

#define _XTAL_FREQ 8000000
#include <xc.h>

// CONFIGURATION BITS
#pragma config FOSC = INTRC_NOCLKOUT
#pragma config WDTE = OFF
#pragma config PWRTE = ON
#pragma config MCLRE = ON
#pragma config CP = OFF
#pragma config CPD = OFF
#pragma config BOREN = ON
#pragma config IESO = OFF
#pragma config FCMEN = OFF
#pragma config LVP = OFF
#pragma config BOR4V = BOR40V
#pragma config WRT = OFF
#pragma config DEBUG = OFF

// ---- Definición de pines ----
// LEDs de temperatura (9 LEDs)
#define LED_AZUL1   RD0
#define LED_AZUL2   RD1
#define LED_AZUL3   RD2
#define LED_BLANCO1 RD3
#define LED_BLANCO2 RD4
#define LED_BLANCO3 RD5
#define LED_ROJO1   RD6
#define LED_ROJO2   RD7
#define LED_ROJO3   RC7

// LEDs de estado (opcionales)
#define LED_CALIENTE    RB7
#define LED_DECENTE     RB5
#define LED_FRIO        RB6

// Selectores de display (activos en bajo)
#define SEL_DECENAS     RC2
#define SEL_UNIDADES    RC3

// Tabla de segmentos para cátodo común (bits: a b c d e f g)
const unsigned char segmentos[] = {
    0b0111111,  // 0
    0b0000110,  // 1
    0b1011011,  // 2
    0b1001111,  // 3
    0b1100110,  // 4
    0b1101101,  // 5
    0b1111101,  // 6
    0b0000111,  // 7
    0b1111111,  // 8
    0b1101111   // 9
};

// Umbrales de temperatura para alarma (rango deseado: 18-40°C)
#define ALARMA_MIN 18
#define ALARMA_MAX 40
#define TEMP_MIN 18
#define TEMP_MAX 40

// Umbrales para los LEDs de color (ajústalos si quieres)
#define LED_FRIO_MAX   17   // <18°C -> azules
#define LED_NORMAL_MIN 18   // 18-40°C -> blancos
#define LED_NORMAL_MAX 40
#define LED_CALIENTE_MIN 41 // 40>°C -> rojos

// Prototipos
void ADC_Init(void);
unsigned int read_adc(void);
void init_pwm(void);
void set_pwm_duty(unsigned char duty);
void actualizar_leds(unsigned int temp);
void mostrar_temperatura(unsigned int temp);
void delay_ms(unsigned int ms);

unsigned int temperatura_actual = 0;

// -----------------------------------------------------------------
void ADC_Init(void) {
    TRISA0 = 1;          // AN0 entrada (LM35)
    ANSEL = 0b00000001;  // Solo AN0 analógico
    ANSELH = 0x00;       // Resto digitales
    ADCON1 = 0b10000000; // Referencias VDD/VSS, justificación derecha
    ADCON0bits.CHS = 0;
    ADCON0bits.ADON = 1;
    ADCON0bits.ADCS0 = 1; // Fosc/8
    ADCON0bits.ADCS1 = 0;
    __delay_us(50);
}

// -----------------------------------------------------------------
unsigned int read_adc(void) {
    ADCON0bits.GO = 1;
    while(ADCON0bits.GO);
    return ((unsigned int)ADRESH << 8) | ADRESL;
}

// -----------------------------------------------------------------
void init_pwm(void) {
    TRISC1 = 0;          // RC1 salida PWM
    CCP2CON = 0b00001100;
    CCPR2L = 0;
    T2CON = 0b00000111;  // Timer2 ON, prescaler 1:16
    set_pwm_duty(0);     // Apagado inicial
}

void set_pwm_duty(unsigned char duty) {
    CCPR2L = duty >> 2;
    CCP2CONbits.DC2B0 = duty & 0b00000001;
    CCP2CONbits.DC2B1 = (duty >> 1) & 0b00000001;
}

// -----------------------------------------------------------------
void actualizar_leds(unsigned int temp) {
    unsigned char num_leds = 0;
    
    // Apagar todos los LEDs de temperatura
    LED_AZUL1 = LED_AZUL2 = LED_AZUL3 = 0;
    LED_BLANCO1 = LED_BLANCO2 = LED_BLANCO3 = 0;
    LED_ROJO1 = LED_ROJO2 = LED_ROJO3 = 0;
    
    // Apagar LEDs de estado
    LED_FRIO = 0;
    LED_DECENTE = 0;
    LED_CALIENTE = 0;
    
    if (temp < TEMP_MIN) {  // TEMP_MIN = 18
        // Zona fría (0-17°C)
        LED_FRIO = 1;
        // Calcular número de LEDs azules: a más frío, más LEDs
        // Mapeo lineal: 0°C -> 3 LEDs, 14°C -> 1 LED (para que se note el cambio)
        // Usamos una regla de tres simple: num = 3 - (temp * 2 / 14) , pero que dé 3 para 0, 2 para 7, 1 para 14
        if (temp <= 5)
            num_leds = 3;
        else if (temp <= 10)
            num_leds = 2;
        else
            num_leds = 1;   // para temp 11-17
        
        if (num_leds >= 1) LED_AZUL1 = 1;
        if (num_leds >= 2) LED_AZUL2 = 1;
        if (num_leds >= 3) LED_AZUL3 = 1;
        
        // PWM proporcional a la cantidad de LEDs (más frío = más intensidad)
        if (num_leds <= 1) set_pwm_duty(64);
        else if (num_leds <= 2) set_pwm_duty(85);
        else set_pwm_duty(128);
    }
    else if (temp >= TEMP_MIN && temp <= TEMP_MAX) {  // TEMP_MAX = 40
        // Zona normal (18-40°C)
        LED_DECENTE = 1;
        // Calcular LEDs blancos (lineal: 18°C -> 1 LED, 40°C -> 3 LEDs)
        if (temp <= 25)
            num_leds = 1;
        else if (temp <= 33)
            num_leds = 2;
        else
            num_leds = 3;
        
        if (num_leds >= 1) LED_BLANCO1 = 1;
        if (num_leds >= 2) LED_BLANCO2 = 1;
        if (num_leds >= 3) LED_BLANCO3 = 1;
        
        if (num_leds <= 1) set_pwm_duty(128);
        else if (num_leds <= 2) set_pwm_duty(170);
        else set_pwm_duty(192);
    }
    else {  // temp > 40°C
        // Zona caliente
        LED_CALIENTE = 1;
        // Calcular LEDs rojos (lineal: 41°C -> 1 LED, 60°C -> 3 LEDs)
        unsigned int exceso = temp - TEMP_MAX;
        if (exceso > 20) exceso = 20;
        if (exceso <= 6)
            num_leds = 1;
        else if (exceso <= 13)
            num_leds = 2;
        else
            num_leds = 3;
        
        if (num_leds >= 1) LED_ROJO1 = 1;
        if (num_leds >= 2) LED_ROJO2 = 1;
        if (num_leds >= 3) LED_ROJO3 = 1;
        
        if (num_leds <= 1) set_pwm_duty(192);
        else if (num_leds <= 2) set_pwm_duty(220);
        else set_pwm_duty(255);
    }
    
    // Alarma sonora SOLO fuera del rango deseado (18-40°C) ? según laboratorio
    if (temp < ALARMA_MIN || temp > ALARMA_MAX) {
        set_pwm_duty(128);   // sonido continuo (50% duty)
    } else {
        set_pwm_duty(0);     // apagar buzzer
    }
}

// -----------------------------------------------------------------
void mostrar_temperatura(unsigned int temp) {
    unsigned char decenas = temp / 10;
    unsigned char unidades = temp % 10;
    
    // Mostrar decenas
    PORTB = segmentos[decenas];
    SEL_DECENAS = 0;
    SEL_UNIDADES = 1;
    __delay_ms(5);
    
    // Mostrar unidades
    PORTB = segmentos[unidades];
    SEL_DECENAS = 1;
    SEL_UNIDADES = 0;
    __delay_ms(5);
    
    // Apagar ambos (para evitar ghosting)
    SEL_DECENAS = 1;
    SEL_UNIDADES = 1;
}

// -----------------------------------------------------------------
void delay_ms(unsigned int ms) {
    while(ms--) __delay_ms(1);
}

// -----------------------------------------------------------------
void main(void) {
    // Oscilador interno a 8 MHz
    OSCCON = 0b01110000;
    while(!OSCCONbits.HTS);
    
    // Configuración de puertos
    TRISB = 0b10000000;   // RB0-RB6 salidas (segmentos)
    TRISD = 0x00;         // LEDs de temperatura en RD0-RD7
    TRISC = 0b00000000;   // RC2, RC3 selectores, RC7 LED rojo3, RC1 PWM
    TRISC1 = 0;           // Salida PWM (lo configura init_pwm)
    TRISC2 = 0; TRISC3 = 0; TRISC7 = 0;
    TRISA = 0b00000001;   // RA0 entrada, resto salidas (incluye RA2-RA4 para LEDs estado)
    ANSEL = 0b00000001;
    ANSELH = 0x00;
    
    // Inicializar puertos
    PORTB = 0x00;
    PORTD = 0x00;
    PORTC = 0x00;
    PORTA = 0x00;
    
    ADC_Init();
    init_pwm();
    
    while(1) {
        unsigned int adc = read_adc();
        // Conversión sin desbordamiento (unsigned long de 32 bits)
        temperatura_actual = ( (unsigned long)adc * 500UL ) / 1024UL;
        
        // Limitar a un rango razonable (0-60°C, el LM35 llega a 55°C)
        if(temperatura_actual > 60) temperatura_actual = 60;
        
        actualizar_leds(temperatura_actual);
        mostrar_temperatura(temperatura_actual);
        
        delay_ms(100);  // 10 lecturas por segundo, suficiente
    }
}
