;==============================================================================
; PROGRAMA: 16 LEDs con 3 modos de secuencia (Ensamblador)
; PIC: 16F887
;==============================================================================

    PROCESSOR 16F887
    #include <xc.inc>                ; Definiciones del PIC

;------------------------------------------------------------------------------
; BITS DE CONFIGURACIÓN (FUSES)
;------------------------------------------------------------------------------
    __CONFIG _CONFIG1, _INTRC_OSC_NOCLKOUT & _WDT_OFF & _PWRTE_ON & _MCLRE_ON & _CP_OFF & _CPD_OFF & _BOREN_ON & _IESO_OFF & _FCMEN_OFF & _LVP_OFF
    __CONFIG _CONFIG2, _BOR4V_BOR40V & _WRT_OFF & _DEBUG_OFF

;------------------------------------------------------------------------------
; VARIABLES EN RAM (Banco 0)
;------------------------------------------------------------------------------
    CBLOCK 0x20
        d1, d2, d3          ; Para delay de 1ms
        ms_low, ms_high     ; Contador de 16 bits para delay en ms
    ENDC

;------------------------------------------------------------------------------
; VECTOR DE RESET
;------------------------------------------------------------------------------
    ORG     0x00
    GOTO    main

;==============================================================================
; SUBRUTINAS DE DELAY
;==============================================================================

;-------------------------------------------------------------------------------
; delay_1ms: Genera un retardo aproximado de 1 ms con oscilador de 8 MHz
;-------------------------------------------------------------------------------
delay_1ms:
    MOVLW   0xFA            ; 250
    MOVWF   d2
d1ms_outer:
    MOVLW   0x08            ; 8
    MOVWF   d3
d1ms_inner:
    DECFSZ  d3, F
    GOTO    d1ms_inner
    DECFSZ  d2, F
    GOTO    d1ms_outer
    RETURN

;-------------------------------------------------------------------------------
; delay_ms16: Retardo en milisegundos usando contador de 16 bits (ms_high:ms_low)
;-------------------------------------------------------------------------------
delay_ms16:
    MOVF    ms_high, W
    IORWF   ms_low, W
    BTFSC   STATUS, Z
    RETURN
    CALL    delay_1ms
    MOVLW   1
    SUBWF   ms_low, F
    BTFSS   STATUS, C
    DECF    ms_high, F
    GOTO    delay_ms16

;==============================================================================
; PROGRAMA PRINCIPAL
;==============================================================================
main:
    ;--- Configurar oscilador interno a 8 MHz ---
    BANKSEL OSCCON
    MOVLW   0x77            ; IRCF = 111 (8 MHz)
    MOVWF   OSCCON
wait_hts:
    BTFSS   OSCCON, 2       ; Bit HTS (bit 2) = 1 cuando el oscilador de alta frecuencia es estable
    GOTO    wait_hts

    ;--- Configurar puertos ---
    BANKSEL TRISB
    CLRF    TRISB           ; RB0-RB7 como salidas
    BANKSEL TRISD
    CLRF    TRISD           ; RD0-RD7 como salidas
    BANKSEL TRISC
    BSF     TRISC, 1        ; RC1 como entrada
    BSF     TRISC, 2        ; RC2 como entrada
    BSF     TRISC, 3        ; RC3 como entrada

    ;--- Inicializar LEDs apagados ---
    BANKSEL PORTB
    CLRF    PORTB
    BANKSEL PORTD
    CLRF    PORTD

;--- Bucle principal ---
main_loop:
    ; Verificar interruptor RC1
    BANKSEL PORTC
    BTFSC   PORTC, 1        ; ¿RC1 = 0? (presionado)
    GOTO    check_rc2
    CALL    modo1
    GOTO    main_delay

check_rc2:
    BTFSC   PORTC, 2        ; ¿RC2 = 0?
    GOTO    check_rc3
    CALL    modo2
    GOTO    main_delay

check_rc3:
    BTFSC   PORTC, 3        ; ¿RC3 = 0?
    GOTO    apagar
    CALL    modo3
    GOTO    main_delay

apagar:
    BANKSEL PORTB
    CLRF    PORTB
    BANKSEL PORTD
    CLRF    PORTD

main_delay:
    ; Pequeño delay de 20 ms para evitar rebotes
    CLRF    ms_high
    MOVLW   20
    MOVWF   ms_low
    CALL    delay_ms16
    GOTO    main_loop

