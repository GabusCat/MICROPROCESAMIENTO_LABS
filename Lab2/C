// pines
//RB0 = LED1
//RB1 = LED2
//RB2 = LED3
//RB3 = LED4
//RB4 = LED5
//RB5 = LED6
//RB6 = LED7
//RB7 = LED8
//RD0 = LED9
//RD1 = LED10
//RD2 = LED11
//RD3 = LED12
//RD4 = LED13
//RD5 = LED14
//RD6 = LED15
//RD7 = LED16

//RC1 = Interruptor modo 1
//RC2 = Interruptor modo 2
//RC3 = Interruptor modo 3

// CONFIGURACIÓN
#include <pic16f887.h>
#define _XTAL_FREQ 8000000  // 8 MHz

#include <xc.h>
//--------------------------------------------------------------------------------------------------------------------------------------------
// CONFIGURATION BITS
#pragma config FOSC = INTRC_NOCLKOUT
#pragma config WDTE = OFF
#pragma config PWRTE = ON
#pragma config MCLRE = ON
#pragma config CP = OFF
#pragma config CPD = OFF
#pragma config BOREN = ON
#pragma config IESO = OFF
#pragma config FCMEN = OFF
#pragma config LVP = OFF
#pragma config BOR4V = BOR40V
#pragma config WRT = OFF
#pragma config DEBUG = OFF

//funciones
void modo1(void);  // Modo secuencia 1 (RC1)
void modo2(void);  // Modo secuencia 2 (RC2)
void modo3(void);  // Modo secuencia 3 (RC3)

void main(void) {

    // --- Configurar oscilador interno a 8 MHz ---
    OSCCONbits.IRCF = 0b111;
    while (!OSCCONbits.HTS);

    // RB0-RB7 como salidas
    TRISB = 0b00000000;
    PORTB = 0x00;
    // RD0-RD7 como salidas
    TRISD = 0b00000000;
    PORTD = 0x00;
    // RC1-RC3 como entradas (interruptores)
    TRISCbits.TRISC1 = 1;
    TRISCbits.TRISC2 = 1;
    TRISCbits.TRISC3 = 1;

    while(1){
        
        if (PORTCbits.RC1 == 0) {      // MODO 1: Interruptor en RC1 presionado
            modo1();                    // Ejecutar modo 1
        }
        else if (PORTCbits.RC2 == 0) { // MODO 2: Interruptor en RC2 presionado
            modo2();                    // Ejecutar modo 2
        }
        else if (PORTCbits.RC3 == 0) { // MODO 3: Interruptor en RC3 presionado
            modo3();                    // Ejecutar modo 3
        }
        else {                          // Ningún interruptor presionado
            PORTB = 0x00;               // Apagar todos los LEDs
            PORTD = 0x00;
        }
        // Pequeño delay para evitar rebotes
        __delay_ms(20);
    }
}

void modo1(void) {
    // MODO 1: Secuencia de LEDs de izq a der (interruptor RC1 presionado)
    // Delay: 50ms
    
    while(PORTCbits.RC1 == 0) {  // Repetir MIENTRAS el interruptor esté presionado
        
        // Secuencia de LEDs (enciende de 1 en 1 hasta 8)
        PORTB = 0b00000001; PORTD = 0b00000000; __delay_ms(50);
        PORTB = 0b00000011; PORTD = 0b00000000; __delay_ms(50);
        PORTB = 0b00000111; PORTD = 0b00000000; __delay_ms(50);
        PORTB = 0b00001110; PORTD = 0b00000000; __delay_ms(50);
        PORTB = 0b00011100; PORTD = 0b00000000; __delay_ms(50);
        PORTB = 0b00111000; PORTD = 0b00000000; __delay_ms(50);
        PORTB = 0b01110000; PORTD = 0b00000000; __delay_ms(50);
        PORTB = 0b11100000; PORTD = 0b00000000; __delay_ms(50);
        PORTB = 0b11000000; PORTD = 0b00000001; __delay_ms(50);
        PORTB = 0b10000000; PORTD = 0b00000011; __delay_ms(50);
        PORTB = 0b00000000; PORTD = 0b00000111; __delay_ms(50);
        PORTB = 0b00000000; PORTD = 0b00001110; __delay_ms(50);
        PORTB = 0b00000000; PORTD = 0b00011100; __delay_ms(50);
        PORTB = 0b00000000; PORTD = 0b00111000; __delay_ms(50);
        PORTB = 0b00000000; PORTD = 0b01110000; __delay_ms(50);
        PORTB = 0b00000000; PORTD = 0b11100000; __delay_ms(50);
        PORTB = 0b00000000; PORTD = 0b11000000; __delay_ms(50);
        PORTB = 0b00000000; PORTD = 0b10000000; __delay_ms(50);
        PORTB = 0b00000000; PORTD = 0b11000000; __delay_ms(50);
        PORTB = 0b00000000; PORTD = 0b11100000; __delay_ms(50);
        PORTB = 0b00000000; PORTD = 0b01110000; __delay_ms(50);
        PORTB = 0b00000000; PORTD = 0b00111000; __delay_ms(50);
        PORTB = 0b00000000; PORTD = 0b00011100; __delay_ms(50);
        PORTB = 0b00000000; PORTD = 0b00001110; __delay_ms(50);
        PORTB = 0b00000000; PORTD = 0b00000111; __delay_ms(50);
        PORTB = 0b10000000; PORTD = 0b00000011; __delay_ms(50);
        PORTB = 0b11000000; PORTD = 0b00000001; __delay_ms(50);
        PORTB = 0b11100000; PORTD = 0b00000000; __delay_ms(50);
        PORTB = 0b01110000; PORTD = 0b00000000; __delay_ms(50);
        PORTB = 0b00111000; PORTD = 0b00000000; __delay_ms(50);
        PORTB = 0b00011100; PORTD = 0b00000000; __delay_ms(50);
        PORTB = 0b00001110; PORTD = 0b00000000; __delay_ms(50);
        PORTB = 0b00000111; PORTD = 0b00000000; __delay_ms(50);
        PORTB = 0b00000011; PORTD = 0b00000000; __delay_ms(50);
        PORTB = 0b00000001; PORTD = 0b00000000; __delay_ms(50);
    }
}

void modo2(void) {
    // MODO 2: Secuencia doble de LEDs de der a izq (interruptor RC2 presionado)
    // Delay: 50ms
    
    while(PORTCbits.RC2 == 0) {  // Repetir MIENTRAS el interruptor esté presionado
        
        // Secuencia de LEDs (enciende de 3 en 1 hasta 16)
        PORTB = 0b00000001; PORTD = 0b10000000; __delay_ms(50);
        PORTB = 0b00000011; PORTD = 0b11000000; __delay_ms(50);
        PORTB = 0b00000111; PORTD = 0b11100000; __delay_ms(50);
        PORTB = 0b00001110; PORTD = 0b01110000; __delay_ms(50);
        PORTB = 0b00011100; PORTD = 0b00111000; __delay_ms(50);
        PORTB = 0b00111000; PORTD = 0b00011100; __delay_ms(50);
        PORTB = 0b01110000; PORTD = 0b00001110; __delay_ms(50);
        PORTB = 0b11100000; PORTD = 0b00000111; __delay_ms(50);
        PORTB = 0b11000000; PORTD = 0b00000011; __delay_ms(50);
        PORTB = 0b10000000; PORTD = 0b00000001; __delay_ms(50);
        PORTB = 0b11000000; PORTD = 0b00000011; __delay_ms(50);
        PORTB = 0b11100000; PORTD = 0b00000111; __delay_ms(50);
        PORTB = 0b01110000; PORTD = 0b00001110; __delay_ms(50);
        PORTB = 0b00111000; PORTD = 0b00011100; __delay_ms(50);
        PORTB = 0b00011100; PORTD = 0b00111000; __delay_ms(50);
        PORTB = 0b00001110; PORTD = 0b01110000; __delay_ms(50);
        PORTB = 0b00000111; PORTD = 0b11100000; __delay_ms(50);
        PORTB = 0b00000011; PORTD = 0b11000000; __delay_ms(50);
        PORTB = 0b00000001; PORTD = 0b10000000; __delay_ms(50);
    }
}

void modo3(void) {
    // MODO 3: Secuencia triple de LEDs (interruptor RC3 presionado)
    // Progresión de delays: 1000ms → 800ms → 400ms → 200ms → 100ms → 50ms → 25ms → 12ms → 6ms → 3ms → 2ms
    
    while(PORTCbits.RC3 == 0) {  // Repetir MIENTRAS el interruptor esté presionado
        
        // ===== 1000ms =====
        PORTB = 0b00000001; PORTD = 0b10000100; __delay_ms(1000);
        PORTB = 0b00000010; PORTD = 0b01000010; __delay_ms(1000);
        PORTB = 0b00000100; PORTD = 0b00100001; __delay_ms(1000);
        PORTB = 0b10001000; PORTD = 0b00010000; __delay_ms(1000);
        PORTB = 0b01010000; PORTD = 0b00001000; __delay_ms(1000);
        PORTB = 0b00110000; PORTD = 0b00001000; __delay_ms(1000);
        
        // ===== 800ms =====
        PORTB = 0b00110000; PORTD = 0b00001000; __delay_ms(800);
        PORTB = 0b01001000; PORTD = 0b00001000; __delay_ms(800);
        PORTB = 0b10000100; PORTD = 0b00001000; __delay_ms(800);
        PORTB = 0b00000010; PORTD = 0b00001001; __delay_ms(800);
        PORTB = 0b00000001; PORTD = 0b00001010; __delay_ms(800);
        PORTB = 0b00000010; PORTD = 0b00001100; __delay_ms(800);
        
        // ===== 400ms =====
        PORTB = 0b00000010; PORTD = 0b00001100; __delay_ms(400);
        PORTB = 0b00000100; PORTD = 0b00010010; __delay_ms(400);
        PORTB = 0b00000100; PORTD = 0b00100001; __delay_ms(400);
        PORTB = 0b10001000; PORTD = 0b01000000; __delay_ms(400);
        PORTB = 0b01001000; PORTD = 0b10000000; __delay_ms(400);
        PORTB = 0b00110000; PORTD = 0b10000000; __delay_ms(400);
        
        // ===== 200ms =====
        PORTB = 0b01001000; PORTD = 0b01000000; __delay_ms(200);
        PORTB = 0b10000100; PORTD = 0b00100000; __delay_ms(200);
        PORTB = 0b00000010; PORTD = 0b00010001; __delay_ms(200);
        PORTB = 0b00000001; PORTD = 0b00001010; __delay_ms(200);
        PORTB = 0b00000010; PORTD = 0b00001100; __delay_ms(200);
        
        // ===== 100ms =====
        PORTB = 0b00000010; PORTD = 0b00001100; __delay_ms(100);
        PORTB = 0b00000100; PORTD = 0b00010010; __delay_ms(100);
        PORTB = 0b00000100; PORTD = 0b00100001; __delay_ms(100);
        PORTB = 0b10001000; PORTD = 0b01000000; __delay_ms(100);
        PORTB = 0b01001000; PORTD = 0b10000000; __delay_ms(100);
        PORTB = 0b00110000; PORTD = 0b01000000; __delay_ms(100);
        
        // ===== 50ms =====
        PORTB = 0b00110000; PORTD = 0b00100000; __delay_ms(50);
        PORTB = 0b01001000; PORTD = 0b00100000; __delay_ms(50);
        PORTB = 0b10000100; PORTD = 0b00010000; __delay_ms(50);
        PORTB = 0b00000010; PORTD = 0b00010001; __delay_ms(50);
        PORTB = 0b00000001; PORTD = 0b00001010; __delay_ms(50);
        PORTB = 0b00000010; PORTD = 0b00001100; __delay_ms(50);
        
        // ===== 25ms =====
        PORTB = 0b00000100; PORTD = 0b00001100; __delay_ms(25);
        PORTB = 0b00000100; PORTD = 0b00010010; __delay_ms(25);
        PORTB = 0b00001000; PORTD = 0b00100001; __delay_ms(25);
        PORTB = 0b10001000; PORTD = 0b01000000; __delay_ms(25);
        PORTB = 0b01010000; PORTD = 0b10000000; __delay_ms(25);
        PORTB = 0b00110000; PORTD = 0b01000000; __delay_ms(25);
        
        // ===== 12ms =====
        PORTB = 0b00110000; PORTD = 0b00100000; __delay_ms(12);
        PORTB = 0b01001000; PORTD = 0b00100000; __delay_ms(12);
        PORTB = 0b10000100; PORTD = 0b00010000; __delay_ms(12);
        PORTB = 0b00000010; PORTD = 0b00010001; __delay_ms(12);
        PORTB = 0b00000001; PORTD = 0b00001010; __delay_ms(12);
        PORTB = 0b00000010; PORTD = 0b00001100; __delay_ms(12);
        
        // ===== 6ms =====
        PORTB = 0b00000100; PORTD = 0b00001100; __delay_ms(6);
        PORTB = 0b00000100; PORTD = 0b00010010; __delay_ms(6);
        PORTB = 0b00001000; PORTD = 0b00100001; __delay_ms(6);
        PORTB = 0b10001000; PORTD = 0b01000000; __delay_ms(6);
        PORTB = 0b01010000; PORTD = 0b10000000; __delay_ms(6);
        PORTB = 0b00110000; PORTD = 0b01000000; __delay_ms(6);
        
        // ===== 3ms =====
        PORTB = 0b01001000; PORTD = 0b00100000; __delay_ms(3);
        PORTB = 0b10000100; PORTD = 0b00010000; __delay_ms(3);
        PORTB = 0b00000010; PORTD = 0b00001001; __delay_ms(3);
        PORTB = 0b00000001; PORTD = 0b00000110; __delay_ms(3);
        PORTB = 0b00000010; PORTD = 0b00010010; __delay_ms(3);
        PORTB = 0b00000100; PORTD = 0b00100001; __delay_ms(3);
        PORTB = 0b10001000; PORTD = 0b01000000; __delay_ms(3);
        PORTB = 0b01010000; PORTD = 0b10000000; __delay_ms(3);
        
        // ===== 2ms (final) =====
        PORTB = 0b01001000; PORTD = 0b00100000; __delay_ms(2);
        PORTB = 0b10000100; PORTD = 0b00010000; __delay_ms(2);
        PORTB = 0b00000010; PORTD = 0b00001001; __delay_ms(2);
        PORTB = 0b00000001; PORTD = 0b00000110; __delay_ms(2);
        PORTB = 0b00000010; PORTD = 0b00010010; __delay_ms(2);
        PORTB = 0b00000100; PORTD = 0b00100001; __delay_ms(2);
        PORTB = 0b10001000; PORTD = 0b01000000; __delay_ms(2);
        PORTB = 0b01010000; PORTD = 0b10000000; __delay_ms(2);
        
        // Final con todos los LEDs encendidos
        PORTB = 0b11111111; PORTD = 0b11111111; __delay_ms(1000);
    }
}
